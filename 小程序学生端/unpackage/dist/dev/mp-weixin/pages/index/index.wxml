<view style="{{'--status-bar-height:' + O + ';' + (virtualHostStyle || '')}}" id="{{N}}" change:eS="{{uV.sS}}" eS="{{$eS[N]}}" change:eA="{{uV.sA}}" eA="{{$eA[N]}}" class="{{['container', P]}}" hidden="{{virtualHostHidden || false}}"><view class="header"><view class="title">扫码签到</view><view class="subtitle">填写学号姓名后扫码，自动带上当前 WiFi BSSID</view></view><view class="card"><view class="card-title">学生信息</view><view class="form"><view class="form-item"><text class="label">学生姓名</text><input class="text-input" placeholder="请输入姓名" disabled="{{a}}" value="{{b}}" bindinput="{{c}}"/></view><view class="form-item"><text class="label">学号</text><input class="text-input" placeholder="请输入学号" disabled="{{d}}" value="{{e}}" bindinput="{{f}}"/></view></view><view class="actions"><button wx:if="{{g}}" class="btn" type="default" catchtap="{{h}}">保存到本机</button><button wx:else class="btn btn-ghost" type="default" catchtap="{{i}}">重新编辑</button><view wx:if="{{j}}" class="bind-tip">已保存到本机</view></view></view><view class="card"><view class="card-title">签到操作</view><view class="scan-button" bindtap="{{l}}"><view class="scan-left"><image class="scan-icon" src="{{k}}" mode="aspectFit"></image><view class="scan-text"><view class="scan-title">扫描签到二维码</view><view class="scan-desc">将自动调用签到接口</view></view></view><view class="scan-right">›</view></view><view class="actions" style="margin-top:16rpx"><button class="btn" type="default" catchtap="{{m}}">查看通知</button></view><view class="chips"><view class="{{['chip', o]}}"><text class="chip-text">微信：{{n}}</text></view><view class="{{['chip', q]}}"><text class="chip-text">信息：{{p}}</text></view><view class="{{['chip', s]}}"><text class="chip-text">定位：{{r}}</text></view><view class="{{['chip', v]}}"><text class="chip-text">WiFi：{{t}}</text></view><view class="{{['chip', x]}}"><text class="chip-text">结果：{{w}}</text></view></view></view><view class="card"><view class="card-title">结果</view><view class="kv"><view class="kv-row"><text class="kv-key">扫描内容</text><text class="kv-val mono">{{y}}</text></view><view class="kv-row"><text class="kv-key">服务返回</text><text class="kv-val mono">{{z}}</text></view></view></view><view class="card"><view class="card-title">网络信息</view><view class="kv"><view class="kv-row"><text class="kv-key">SSID</text><text class="kv-val">{{A}}</text></view><view class="kv-row"><text class="kv-key">BSSID（device_id）</text><text class="kv-val mono">{{B}}</text></view><view class="kv-row"><text class="kv-key">可见 WiFi 数</text><text class="kv-val">{{C}}</text></view></view><view class="actions"><button class="btn" type="default" catchtap="{{E}}">{{D}}</button></view><view wx:if="{{F}}" class="wifi-list"><view wx:for="{{G}}" wx:for-item="w" wx:key="c" class="wifi-item"><view class="wifi-name">{{w.a}}</view><view class="wifi-meta mono">{{w.b}}</view></view></view></view><view wx:if="{{H}}" class="modal-overlay" bindtap="{{M}}"><view class="modal-content" catchtap="{{L}}"><view class="modal-header"><text class="modal-title">通知</text></view><view class="modal-body"><view wx:if="{{I}}"><view wx:for="{{J}}" wx:for-item="alert" wx:key="c" class="alert-item"><view class="alert-icon">⚠️</view><view class="alert-content"><view class="alert-title">{{alert.a}}提醒你去上课了</view><view class="alert-time">{{alert.b}}</view></view></view></view><view wx:else class="alert-empty"><view class="alert-icon">ℹ️</view><view class="alert-content"><view class="alert-title">暂无通知</view></view></view></view><view class="modal-footer"><button class="btn" bindtap="{{K}}">我知道了</button></view></view></view></view><wxs src="/common/uniView.wxs" module="uV"/>
