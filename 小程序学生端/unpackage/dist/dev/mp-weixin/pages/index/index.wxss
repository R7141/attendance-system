@import "../../uvue.wxss";
:host{display:flex;flex-direction:column}

.container {
		min-height: 100vh;
		padding: 40rpx;
		background: linear-gradient(180deg, #eef5ff 0%, #f6f7fb 55%, #f5f5f5 100%);
}
.header {
		margin-bottom: 24rpx;
}
.title {
		font-size: 44rpx;
		color: #1f2937;
		font-weight: 700;
		letter-spacing: 1rpx;
}
.subtitle {
		margin-top: 10rpx;
		font-size: 26rpx;
		color: #6b7280;
}
.card {
		background-color: #ffffff;
		border-radius: 18rpx;
		padding: 24rpx;
		margin-bottom: 20rpx;
		box-shadow: 0 10rpx 30rpx rgba(17, 24, 39, 0.08);
		border: 1rpx solid rgba(229, 231, 235, 0.7);
}
.card-title {
		font-size: 28rpx;
		color: #374151;
		font-weight: 600;
		margin-bottom: 16rpx;
}
.form {
		display: flex;
		flex-direction: column;
		gap: 18rpx;
}
.form-item {
		display: flex;
		flex-direction: column;
		gap: 10rpx;
}
.label {
		display: block;
		font-size: 26rpx;
		color: #6b7280;
}
.text-input {
		background-color: #f9fafb;
		border-radius: 14rpx;
		padding: 22rpx;
		font-size: 30rpx;
		height: 100rpx;
		border: 1rpx solid #e5e7eb;
}
.scan-button {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 18rpx 18rpx;
		border-radius: 16rpx;
		background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
		color: #fff;
}
.scan-left {
		display: flex;
		align-items: center;
		gap: 14rpx;
}
.scan-icon {
		width: 72rpx;
		height: 72rpx;
		background-color: rgba(255, 255, 255, 0.18);
		border-radius: 16rpx;
		padding: 10rpx;
}
.scan-text {
		display: flex;
		flex-direction: column;
		gap: 6rpx;
}
.scan-title {
		font-size: 30rpx;
		font-weight: 700;
		color: #fff;
}
.scan-desc {
		font-size: 24rpx;
		color: rgba(255, 255, 255, 0.85);
}
.scan-right {
		font-size: 44rpx;
		color: rgba(255, 255, 255, 0.9);
		padding-left: 12rpx;
}
.chips {
		display: flex;
		gap: 12rpx;
		margin-top: 16rpx;
		flex-wrap: wrap;
}
.chip {
		padding: 10rpx 14rpx;
		border-radius: 999rpx;
		border: 1rpx solid #e5e7eb;
		background-color: #f9fafb;
}
.chip-text {
		font-size: 24rpx;
		color: #374151;
}
.chip-ok {
		background-color: #ecfdf5;
		border-color: #a7f3d0;
}
.chip-ok .chip-text {
		color: #065f46;
}
.chip-warn {
		background-color: #fff7ed;
		border-color: #fed7aa;
}
.chip-warn .chip-text {
		color: #9a3412;
}
.chip-muted {
		background-color: #f3f4f6;
		border-color: #e5e7eb;
}
.kv {
		display: flex;
		flex-direction: column;
		gap: 14rpx;
}
.kv-row {
		display: flex;
		flex-direction: column;
		gap: 8rpx;
		padding: 16rpx;
		border-radius: 14rpx;
		background-color: #f9fafb;
		border: 1rpx solid #e5e7eb;
}
.kv-key {
		font-size: 24rpx;
		color: #6b7280;
}
.kv-val {
		font-size: 26rpx;
		color: #111827;
		word-break: break-all;
		line-height: 36rpx;
}
.mono {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
}
.actions {
		margin-top: 16rpx;
		display: flex;
		justify-content: flex-end;
}
.bind-tip {
		font-size: 24rpx;
		color: #6b7280;
		align-self: center;
}
.btn {
		border-radius: 999rpx;
		padding: 14rpx 18rpx;
		font-size: 26rpx;
		border: 1rpx solid #e5e7eb;
		background-color: #ffffff;
}
.btn-ghost {
		margin-left: 12rpx;
		background-color: #f9fafb;
		color: #111827;
}
.wifi-list {
		margin-top: 16rpx;
		display: flex;
		flex-direction: column;
		gap: 10rpx;
}
.wifi-item {
		padding: 14rpx 16rpx;
		border-radius: 14rpx;
		border: 1rpx solid #e5e7eb;
		background-color: #ffffff;
}
.wifi-name {
		font-size: 26rpx;
		color: #111827;
		margin-bottom: 6rpx;
}
.wifi-meta {
				font-size: 24rpx;
				color: #6b7280;
}

		/* 模态框样式 */
.modal-overlay {
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			bottom: 0;
			background-color: rgba(0, 0, 0, 0.5);
			display: flex;
			justify-content: center;
			align-items: center;
			z-index: 9999;
}
.modal-content {
			background-color: #ffffff;
			border-radius: 20rpx;
			width: 80%;
			max-width: 500rpx;
			box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.15);
}
.modal-header {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 24rpx;
			border-bottom: 1rpx solid #e5e7eb;
}
.modal-title {
			font-size: 32rpx;
			font-weight: 700;
			color: #111827;
}
.modal-close {
			font-size: 40rpx;
			color: #6b7280;
			padding: 8rpx;
			line-height: 1;
}
.modal-body {
			padding: 24rpx;
}
.alert-item {
			display: flex;
			align-items: flex-start;
			gap: 16rpx;
			padding: 16rpx 0;
			border-bottom: 1rpx solid #f3f4f6;
}
.alert-item:last-child {
			border-bottom: none;
}
.alert-icon {
			font-size: 32rpx;
			margin-top: 4rpx;
}
.alert-content {
			flex: 1;
}
.alert-title {
			font-size: 28rpx;
			color: #111827;
			margin-bottom: 8rpx;
			font-weight: 600;
}
.alert-time {
			font-size: 24rpx;
			color: #6b7280;
}
.alert-empty {
			display: flex;
			gap: 16rpx;
			align-items: center;
			padding: 24rpx 0;
}
.modal-footer {
			padding: 24rpx;
			border-top: 1rpx solid #e5e7eb;
			display: flex;
			justify-content: center;
}
		